# 加载绘图库
if (!require(ggplot2)) install.packages("ggplot2")
library(ggplot2)
# 1. 创建一个单位圆 (这是我们的原始数据)
theta <- seq(0, 2*pi, length.out = 100)
circle <- data.frame(x = cos(theta), y = sin(theta))
# 2. 定义一个变换矩阵 A (你可以随意修改这里的数字)
# 这个矩阵代表了一个组合动作：旋转 + 拉伸
A <- matrix(c(2, 1, 1, 3), nrow = 2)
View(A)
# 3. 对矩阵 A 进行奇异值分解 (SVD)
# A = U %*% Sigma %*% t(V)
s <- svd(A)
U <- s$u
Sigma <- diag(s$d)
V_t <- t(s$v)
# 4. 计算变换后的点
# 我们看看 A 是如何把圆变成椭圆的
transformed_points <- as.matrix(circle) %*% t(A)
transformed_df <- data.frame(x = transformed_points[,1], y = transformed_points[,2])
# 5. 绘图对比
p1 <- ggplot(circle, aes(x, y)) +
geom_path(color = "blue", size = 1) +
coord_fixed() +
ggtitle("1. 原始单位圆 (Input)") +
theme_minimal()
p2 <- ggplot(transformed_df, aes(x, y)) +
geom_path(color = "red", size = 1) +
# 画出奇异向量 (U 的列向量乘以奇异值)
geom_segment(aes(x=0, y=0, xend=U[1,1]*s$d[1], yend=U[2,1]*s$d[1]),
arrow = arrow(), color = "darkgreen", size = 1.2) +
geom_segment(aes(x=0, y=0, xend=U[1,2]*s$d[2], yend=U[2,2]*s$d[2]),
arrow = arrow(), color = "darkgreen", size = 1.2) +
coord_fixed() +
ggtitle("2. 变换后的椭圆 (A x Circle)") +
annotate("text", x = 2, y = 3, label = "绿线 = 奇异向量 U * Sigma", color = "darkgreen") +
theme_minimal()
# 打印图像
print(p1)
print(p2)
install.packages("rgl")
# 如果没有安装 rgl，请先运行: install.packages("rgl")
library(rgl)
# 1. 生成超正方体的16个顶点 (4维坐标)
vertices_4d <- as.matrix(expand.grid(c(-1, 1), c(-1, 1), c(-1, 1), c(-1, 1)))
# 2. 定义投影函数：将4D转为3D
# 我们让物体在 4D 空间的 xw 平面旋转，产生那种“内外穿透”的效果
project_4d_to_3d <- function(v, angle) {
# 4D 旋转矩阵 (在 xw 平面旋转)
cos_a <- cos(angle)
sin_a <- sin(angle)
# 旋转变换
x_rot <- v[,1] * cos_a - v[,4] * sin_a
w_rot <- v[,1] * sin_a + v[,4] * cos_a
# 透视投影到 3D (d 是观察距离)
d <- 3
factor <- 1 / (d - w_rot)
x3d <- x_rot * factor
y3d <- v[,2] * factor
z3d <- v[,3] * factor
return(cbind(x3d, y3d, z3d))
}
# 3. 找出需要连接的棱 (如果两个顶点间只有一个坐标不同，则连线)
edges <- t(combn(16, 2))
dist_sq <- rowSums((vertices_4d[edges[,1],] - vertices_4d[edges[,2],])^2)
edge_list <- edges[dist_sq == 4, ] # 欧氏距离平方为4代表只有一维不同
# 4. 动画演示
open3d()
bg3d("black")
# 4. 动画演示
open3d()
bg3d("black")
for (i in seq(0, 2*pi, length.out = 300)) {
clear3d()
points_3d <- project_4d_to_3d(vertices_4d, i)
# 画点
spheres3d(points_3d, radius = 0.05, color = "cyan")
# 画棱
for (j in 1:nrow(edge_list)) {
segments3d(points_3d[edge_list[j,], ], color = "white", lwd = 2)
}
# 稍微延迟以产生动画效果
Sys.sleep(0.02)
}
# 绘制超正方体的 Petrie 投影 (正八边形结构)
library(ggplot2)
# 定义 8 个顶点的角度 (正八边形)
theta <- seq(0, 2*pi, length.out = 9)[-9]
# 外部八边形 (代表一部分顶点)
outer_x <- cos(theta)
outer_y <- sin(theta)
# 内部八边形 (代表另一部分顶点，通常半径较小且有旋转偏移)
inner_x <- 0.5 * cos(theta + pi/8)
inner_y <- 0.5 * sin(theta + pi/8)
df <- data.frame(
x = c(outer_x, inner_x),
y = c(outer_y, inner_y),
id = 1:16
)
# 简化版的连接逻辑：展示对称性
ggplot(df, aes(x, y)) +
geom_point(color = "cyan", size = 3) +
# 这里为了清晰，仅示意部分连接
theme_void() +
theme(panel.background = element_rect(fill = "black")) +
coord_fixed()
library(rgl)
plot.sphere=function(k=3, animation=F) {
##k维球面 in (k+1)欧氏空间
X=NULL #点的行走轨迹
N=10000
a=b=c=d=e=0 #球坐标角度
for (i in 1:N){
if (k==2){ #R^3 中的2维球面
a=a+1*pi/N #纬度1, (0,pi)
b=b+100*2*pi/N #经度2, (0,100*pi), 转100圈
x = c(cos(a),sin(a)*cos(b),sin(a)*sin(b)) #球坐标
}
if (k==3){
a=a+1*pi/N #纬度1, (0,pi)
b=b+1*pi/N #维度2, (0,pi)
c=c+100*2*pi/N #经度, (0, 100*pi), 转100圈
x = c(cos(a),sin(a)*cos(b),sin(a)*sin(b)*cos(c),sin(a)*sin(b)*sin(c)) #球坐标
}
X=rbind(X,x)
}
## 投影到3维：
u=matrix(rnorm((k+1)*3), k+1,3)
P=u%*%solve(t(u)%*%(u))%*%t(u) #随机取一个投影矩阵
#Y=X%*%P; #投影
Y=X%*%u%*%solve(t(u)%*%(u))#投影坐标
Y=Y[,c(1,2,3)]
plot3d(Y, xlab="",ylab="",zlab="", size=1,axes=F)
## 动画：
M <- par3d("userMatrix")
f=par3dinterp(time = (0:2)*12, zoom=c(1,1,1 ),
userMatrix = list(M,rotate3d(M,pi , -1,0,-1),rotate3d(M,  pi,1,1,-1)))
duriation=10
play3d(f , duration =duriation)
## 将动画存成moive.gif (dir指定存放位置，getwd() 为当前工作目录), 这一步比较耗时
if (animation)  movie3d(f, duration = 10, dir=getwd(), clean=T)
}
#例子
plot.sphere(k=3)
plot.sphere(k=3, animation=T) #制作动画
