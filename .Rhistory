library(ggplot2)
library(reshape2)
set.seed(42)
# Softmax：把任意数值变成概率分布（加起来=1）
softmax <- function(x) {
# 减去最大值，防止数值溢出（数学上等价，但更稳定）
e_x <- exp(x - max(x))
return(e_x / sum(e_x))
}
# 矩阵版 Softmax（对每一行做 softmax）
softmax_matrix <- function(mat) {
t(apply(mat, 1, softmax))
}
self_attention <- function(X, W_Q, W_K, W_V) {
# X: 输入矩阵，形状 [seq_len × d_model]
#    每一行是一个词的向量表示
# W_Q, W_K, W_V: 可学习的权重矩阵
d_k <- ncol(W_K)  # K 的维度（用于缩放）
# Step 1: 计算 Q、K、V
Q <- X %*% W_Q   # [seq_len × d_k]
K <- X %*% W_K   # [seq_len × d_k]
V <- X %*% W_V   # [seq_len × d_v]
# Step 2: 计算注意力分数
# Q × K^T 得到 [seq_len × seq_len] 的相关性矩阵
scores <- (Q %*% t(K)) / sqrt(d_k)
# Step 3: Softmax 归一化 → 注意力权重
attn_weights <- softmax_matrix(scores)
# Step 4: 加权求和 V
output <- attn_weights %*% V
return(list(
output = output,
attention_weights = attn_weights,
Q = Q, K = K, V = V
))
}
positional_encoding <- function(seq_len, d_model) {
PE <- matrix(0, nrow = seq_len, ncol = d_model)
for (pos in 1:seq_len) {
for (i in seq(1, d_model, by = 2)) {
# 偶数维度用 sin
PE[pos, i] <- sin(pos / 10000^((i-1)/d_model))
# 奇数维度用 cos
if (i + 1 <= d_model) {
PE[pos, i+1] <- cos(pos / 10000^((i-1)/d_model))
}
}
}
return(PE)
}
ffn <- function(X, W1, b1, W2, b2) {
# ReLU 激活函数：负数变0，正数不变
relu <- function(x) pmax(0, x)
hidden <- relu(X %*% W1 + matrix(rep(b1, nrow(X)), nrow=nrow(X), byrow=TRUE))
output <- hidden %*% W2 + matrix(rep(b2, nrow(hidden)), nrow=nrow(hidden), byrow=TRUE)
return(output)
}
# ---------------------------
# 5. Layer Normalization
# ---------------------------
layer_norm <- function(X, eps = 1e-6) {
mu    <- rowMeans(X)
sigma <- apply(X, 1, sd)
# 广播：对每行标准化
X_norm <- (X - mu) / (sigma + eps)
return(X_norm)
}
# ---------------------------
# 6. 完整的一个 Transformer Block
# ---------------------------
transformer_block <- function(X, W_Q, W_K, W_V, W1, b1, W2, b2) {
# Sub-layer 1: Self-Attention + 残差连接 + Layer Norm
attn_result <- self_attention(X, W_Q, W_K, W_V)
X1 <- layer_norm(X + attn_result$output)  # 残差连接
# Sub-layer 2: FFN + 残差连接 + Layer Norm
ffn_out <- ffn(X1, W1, b1, W2, b2)
X2 <- layer_norm(X1 + ffn_out)            # 残差连接
return(list(output = X2, attention_weights = attn_result$attention_weights))
}
cat("=== Transformer Self-Attention 演示 ===\n\n")
# 假设我们有一个4词的句子，每个词用8维向量表示
# 词: ["我", "爱", "吃", "苹果"]
seq_len <- 4
d_model <- 8
d_k     <- 4  # Q/K 维度
d_v     <- 4  # V 维度
d_ff    <- 16 # FFN 隐藏层维度
# 模拟词嵌入（实际中这是从训练中学到的）
words <- c("我", "爱", "吃", "苹果")
X_embed <- matrix(rnorm(seq_len * d_model), nrow = seq_len, ncol = d_model)
rownames(X_embed) <- words
cat("📝 输入句子：", paste(words, collapse=" "), "\n")
cat("📐 词嵌入矩阵形状：", nrow(X_embed), "×", ncol(X_embed), "\n\n")
# 加入位置编码
PE <- positional_encoding(seq_len, d_model)
X_with_pos <- X_embed + PE
cat("✅ 已加入位置编码（让模型知道词的顺序）\n\n")
# 初始化权重矩阵（实际中通过训练学习）
W_Q <- matrix(rnorm(d_model * d_k, sd=0.1), nrow=d_model, ncol=d_k)
W_K <- matrix(rnorm(d_model * d_k, sd=0.1), nrow=d_model, ncol=d_k)
W_V <- matrix(rnorm(d_model * d_v, sd=0.1), nrow=d_model, ncol=d_v)
W1 <- matrix(rnorm(d_v * d_ff, sd=0.1), nrow=d_v, ncol=d_ff)
b1 <- rep(0, d_ff)
W2 <- matrix(rnorm(d_ff * d_v, sd=0.1), nrow=d_ff, ncol=d_v)
b2 <- rep(0, d_v)
# 运行 Self-Attention
attn_result <- self_attention(X_with_pos, W_Q, W_K, W_V)
attn_weights <- attn_result$attention_weights
rownames(attn_weights) <- words
colnames(attn_weights) <- words
cat("🔍 注意力权重矩阵（每行加起来=1）：\n")
print(round(attn_weights, 3))
cat("\n解读：第i行第j列 = 词i在处理时对词j的关注程度\n\n")
# 运行完整 Transformer Block
block_result <- transformer_block(X_with_pos, W_Q, W_K, W_V, W1, b1, W2, b2)
# 运行完整 Transformer Block
block_result <- transformer_block(X_with_pos, W_Q, W_K, W_V, W1, b1, W2, b2)
# ============================================================
# "Attention Is All You Need" 完整 R 复现
# Vaswani et al., NeurIPS 2017
# ============================================================
library(ggplot2); library(reshape2); library(gridExtra)
set.seed(2017)
# ── 工具函数 ──────────────────────────────────────────────
softmax_row <- function(mat) {
t(apply(mat, 1, function(row) { e <- exp(row - max(row)); e / sum(e) }))
}
layer_norm <- function(X, eps=1e-6) {
sweep(sweep(X, 1, rowMeans(X), "-"), 1, apply(X,1,sd)+eps, "/")
}
relu <- function(x) pmax(0, x)
# ── 1. 位置编码（论文 Section 3.5）────────────────────────
positional_encoding <- function(seq_len, d_model) {
PE <- matrix(0, seq_len, d_model)
for (pos in 1:seq_len)
for (i in seq(1, d_model, 2)) {
PE[pos,i]           <- sin(pos / 10000^((i-1)/d_model))
if(i+1<=d_model) PE[pos,i+1] <- cos(pos / 10000^((i-1)/d_model))
}
PE
}
# ── 2. 缩放点积注意力（论文公式1）────────────────────────
scaled_dot_product_attention <- function(Q, K, V, mask=NULL) {
scores <- (Q %*% t(K)) / sqrt(ncol(K))
if (!is.null(mask)) scores[mask==0] <- -1e9
attn <- softmax_row(scores)
list(output=attn %*% V, weights=attn)
}
# ── 3. 多头注意力（论文 Section 3.2.2）───────────────────
multi_head_attention <- function(Xq, Xk, Xv, Wq, Wk, Wv, WO, mask=NULL) {
h <- length(Wq)
heads <- lapply(1:h, function(i)
scaled_dot_product_attention(Xq%*%Wq[[i]], Xk%*%Wk[[i]], Xv%*%Wv[[i]], mask))
output <- do.call(cbind, lapply(heads, `[[`, "output")) %*% WO
list(output=output, all_weights=lapply(heads, `[[`, "weights"))
}
# ── 4. 前馈网络（论文 Section 3.3）───────────────────────
feed_forward <- function(X, W1, b1, W2, b2) {
n <- nrow(X)
relu(X%*%W1 + matrix(rep(b1,n),n,byrow=T)) %*% W2 +
matrix(rep(b2,n),n,byrow=T)
}
# ── 5. Encoder 层 ─────────────────────────────────────────
encoder_layer <- function(X, Wq, Wk, Wv, WO, W1,b1,W2,b2) {
a  <- multi_head_attention(X, X, X, Wq, Wk, Wv, WO)
X1 <- layer_norm(X + a$output)
X2 <- layer_norm(X1 + feed_forward(X1, W1,b1,W2,b2))
list(output=X2, attn=a$all_weights)
}
# ── 6. Decoder 层 ─────────────────────────────────────────
decoder_layer <- function(Xd, enc_out, Wq1,Wk1,Wv1,WO1,
Wq2,Wk2,Wv2,WO2, W1,b1,W2,b2) {
mask <- lower.tri(matrix(1,nrow(Xd),nrow(Xd)), diag=T)
a1   <- multi_head_attention(Xd, Xd, Xd, Wq1,Wk1,Wv1,WO1, mask)
X1   <- layer_norm(Xd + a1$output)
a2   <- multi_head_attention(X1, enc_out, enc_out, Wq2,Wk2,Wv2,WO2)
X2   <- layer_norm(X1 + a2$output)
X3   <- layer_norm(X2 + feed_forward(X2,W1,b1,W2,b2))
list(output=X3, self_attn=a1$all_weights, cross_attn=a2$all_weights)
}
# ── 7. 初始化权重 ─────────────────────────────────────────
init_mha <- function(dm, h) {
dk <- dm/h
list(Wq=lapply(1:h, \(i) matrix(rnorm(dm*dk,.0,.02),dm,dk)),
Wk=lapply(1:h, \(i) matrix(rnorm(dm*dk,.0,.02),dm,dk)),
Wv=lapply(1:h, \(i) matrix(rnorm(dm*dk,.0,.02),dm,dk)),
WO=matrix(rnorm(h*dk*dm,.0,.02),h*dk,dm))
}
init_ffn <- function(dm, dff)
list(W1=matrix(rnorm(dm*dff,.0,.02),dm,dff), b1=rep(0,dff),
W2=matrix(rnorm(dff*dm,.0,.02),dff,dm), b2=rep(0,dm))
# ── 8. 运行演示（缩小参数以便演示）──────────────────────
# 论文原版: d_model=512, h=8, N=6, d_ff=2048
dm <- 16; h <- 2; dff <- 32; N <- 2
enc_w <- c("The","cat","sat","on","the","mat")
dec_w <- c("<start>","Die","Katze","saß")
Xe <- matrix(rnorm(length(enc_w)*dm), length(enc_w), dm) +
positional_encoding(length(enc_w), dm)
Xd <- matrix(rnorm(length(dec_w)*dm), length(dec_w), dm) +
positional_encoding(length(dec_w), dm)
rownames(Xe) <- enc_w; rownames(Xd) <- dec_w
# Encoder 前向传播
enc_mha <- lapply(1:N, \(l) init_mha(dm,h))
enc_ffn <- lapply(1:N, \(l) init_ffn(dm,dff))
enc_out <- Xe; enc_attn <- list()
for (l in 1:N) {
r <- encoder_layer(enc_out,
enc_mha[[l]]$Wq, enc_mha[[l]]$Wk, enc_mha[[l]]$Wv, enc_mha[[l]]$WO,
enc_ffn[[l]]$W1, enc_ffn[[l]]$b1, enc_ffn[[l]]$W2, enc_ffn[[l]]$b2)
enc_out <- r$output; enc_attn[[l]] <- r$attn
}
