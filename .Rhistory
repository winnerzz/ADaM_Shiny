#ses分组
table1_part1 <- tbl_summary(
data,
by = SES_level,
include = c(
age, gender, Waist, Height,              # 连续变量
WASO_h,  # 根据数据匹配变量名
AWAKE_h,
Drink, Smoke, marry_group,
DB, HTN, DLLP, CHD, LIVER,
HEI, race_group, edu_group, HIS_group, PIR_group, bmigroup2, brigroup2,BMI,BRI,BUN,sleep_du,PA
),
type = list(
c(age, Waist, Height, WASO_h, AWAKE_h, HEI,BMI,BRI,BUN) ~ "continuous",
c(Drink, Smoke, gender, DB, edu_group, HIS_group, HTN, DLLP, CHD, LIVER) ~ "categorical",  # 二分类变量
c(marry_group, race_group, PIR_group,bmigroup2,brigroup2) ~ "categorical"                    # 多分类变量
),
digits = all_continuous() ~ 1  # 直接在此处指定小数位数
)
